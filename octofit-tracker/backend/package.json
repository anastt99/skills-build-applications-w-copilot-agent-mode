{
  "name": "octofit-tracker-backend",
  "version": "1.0.0",
  "description": "OctoFit Tracker backend with Express, TypeScript, and MongoDB",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --esm src/index.ts",
    "seed": "ts-node --esm --transpile-only src/scripts/seed.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo \"No lint configured\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.5",
